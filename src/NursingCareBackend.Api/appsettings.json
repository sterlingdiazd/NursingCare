{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=NursingCareDb;User Id=sa;Password={SQL_PASSWORD};TrustServerCertificate=True;"
  },
  "AllowedHosts": "*",
