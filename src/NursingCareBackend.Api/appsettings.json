{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server={DB_SERVER};Database={DB_NAME};User Id={DB_USER};Password={DB_PASSWORD};TrustServerCertificate=True;"
  },
  "AllowedHosts": "*",
  "Cors": {
    "WebOrigins": ["http://localhost:3000"],
    "MobileOrigins": ["http://localhost:19006"]
  },
  "Jwt": {
    "Issuer": "NursingCareBackend",
    "Audience": "NursingCareClients",
    "Key": "NursingCareBackendSecretKey12345678901234567890"
  },
  "GoogleOAuth": {
    "ClientId": "",
    "ClientSecret": "",
    "RedirectUri": "",
    "FrontendRedirectUrl": "http://localhost:3000/login"
  }
}
