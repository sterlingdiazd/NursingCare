{
  "info": {
    "_postman_id": "nursing-care-api",
    "name": "Nursing Care Backend API",
    "description": "Collection for testing Nursing Care Backend API endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nurse1@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"confirmPassword\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/register",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "register"
              ]
            },
            "description": "Register a new user and get JWT token"
          },
          "response": []
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nurse1@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/auth/login",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            },
            "description": "Login with email and password"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Care Requests",
      "item": [
        {
          "name": "Create Care Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"residentId\": \"11111111-1111-1111-1111-111111111111\",\n  \"description\": \"Patient needs assistance with medication administration.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/api/care-requests",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "care-requests"
              ]
            },
            "description": "Create a new care request (requires authentication)"
          },
          "response": []
        },
        {
          "name": "Get All Care Requests",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/care-requests",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "care-requests"
              ]
            },
            "description": "Get all care requests (requires authentication)"
          },
          "response": []
        },
        {
          "name": "Get Care Request by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/api/care-requests/{{REQUEST_ID}}",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "api",
                "care-requests",
                "{{REQUEST_ID}}"
              ]
            },
            "description": "Get a specific care request by ID (requires authentication)"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{BASE_URL}}/health",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Check API health status"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5050",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    },
    {
      "key": "REQUEST_ID",
      "value": "",
      "type": "string"
    }
  ]
}
